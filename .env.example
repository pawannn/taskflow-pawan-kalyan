ENV=PROD

APP_NAME=taskflow
APP_PORT=1337

# For local dev (without Docker) — use localhost
# docker-compose overrides this automatically to point at the 'db' container
DB_URL=postgres://taskflow:taskflow@localhost:5432/taskflow?sslmode=disable

# REQUIRED — change this to a long random string in production
JWT_SECRET=901f050af3b0ff4872cb414ab2da1a8316762536d5b94dd1d5b20879babd301c
JWT_EXPIRY=24

BCRYPT_COST=12

# PostgreSQL credentials — used by docker-compose to create the database
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
